# Copy to .env.local and adjust as needed.
# The FastAPI backend must be running at this URL.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# NextAuth — required for authentication
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-use-openssl-rand-base64-32

# Google OAuth — create credentials at console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Shared secret used to sign backend JWTs (must match BACKEND_JWT_SECRET in backend .env)
BACKEND_JWT_SECRET=change-me-use-openssl-rand-base64-32
